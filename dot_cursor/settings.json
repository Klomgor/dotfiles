{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
      "source.fixAll.eslint": true
  },
  "eslint.workingDirectories": [
      {
          "mode": "auto"
      }
  ],
  "typescript.tsdk": "node_modules/typescript/lib",
  "files.exclude": {
      "**/.git": true,
      "**/.DS_Store": true,
      "**/node_modules": true,
      "**/dist": true
  },
  "search.exclude": {
      "**/node_modules": true,
      "**/dist": true
  }
}