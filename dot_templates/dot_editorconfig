# EditorConfig: https://editorconfig.org
root = true

# Default settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# Web development
[*.{js,jsx,ts,tsx,css,scss,html,json,yml,yaml}]
indent_style = space
indent_size = 2

# Python
[*.{py,pyi}]
indent_style = space
indent_size = 4
max_line_length = 88  # Black formatter default

# Documentation
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Config files
[*.{json,yml,yaml,toml}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
